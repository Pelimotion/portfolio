{
  "redirects": [
    { "source": "/v1", "destination": "/v1/", "permanent": true },
    { "source": "/curriculum", "destination": "/curriculum/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/v1/", "destination": "/V1/portfolio/index.html" },
    { "source": "/v1/:path*", "destination": "/V1/portfolio/:path*" },
    { "source": "/curriculum", "destination": "/Curriculum/index.html" },
    { "source": "/curriculum/:path*", "destination": "/Curriculum/:path*" }
  ]
}
